# Papercopilot dataset cache (regeneratable via download_papers.py).
# __pycache__/ and results/ are covered by the root .gitignore.
.cache/

# Downloaded PDFs (regeneratable via download_papers.py).
papers/

# Local configs — ignore all, un-ignore the canonical ones.
configs/*.yaml
!configs/baseline.yaml
!configs/frontier.yaml
!configs/coarse.yaml
!configs/reviewer3.yaml

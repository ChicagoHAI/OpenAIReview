# Result directories (large, regenerable)
results*/
_temp_results/

# Sample paper sources (data, not code; users supply their own)
papers/
data/

# Reports (regeneratable from results/)
reports/

# Experiment configs are local except the committed example and the per-domain
# configs that reproduce the paper (run with --configs configs/full_*.yaml).
configs/*
!configs/default.yaml
!configs/full_*.yaml

# Python
__pycache__/

# Jupyter
*.ipynb
.ipynb_checkpoints/

*.pdf
